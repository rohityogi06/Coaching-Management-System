<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Fees</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include("partials/navbar") %>

<section class="form-section">

    <div class="form-container">

        <h2>✏️ Edit Student Fees</h2>

        <form action="/admin/fees/edit/<%= fee.id %>" method="POST">

            <label>Select Student</label>

            <select name="student_id" required>

                <% students.forEach(student => { %>

                    <option
                        value="<%= student.id %>"
                        <%= student.id === fee.student_id ? "selected" : "" %>>
                        <%= student.name %>
                    </option>

                <% }) %>

            </select>

            <label>Amount</label>

            <input
                type="number"
                name="amount"
                value="<%= fee.amount %>"
                required
            >

            <label>Payment Date</label>

            <input
                type="date"
                name="payment_date"
                value="<%= fee.payment_date.toISOString().split('T')[0] %>"
                required
            >

            <label>Status</label>

            <select name="status">

                <option
                    value="Paid"
                    <%= fee.status === "Paid" ? "selected" : "" %>>
                    Paid
                </option>

                <option
                    value="Pending"
                    <%= fee.status === "Pending" ? "selected" : "" %>>
                    Pending
                </option>

            </select>

            <br><br>

            <button type="submit">
                Update Fees
            </button>

        </form>

    </div>

</section>

<%- include("partials/footer") %>
<script src="/js/script.js"></script>
</body>
</html>