<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<title>Admin Profile</title>

<link rel="stylesheet" href="/css/style.css">

</head>

<body>

<%- include("partials/navbar") %>

<section class="form-section">

<div class="form-container">

<h2>👤 Admin Profile</h2>

<!-- Success Message -->
<% if (typeof success !== 'undefined') { %>

<div class="success-message">
    <%= success %>
</div>

<% } %>

<!-- Error Message -->
<% if (typeof error !== 'undefined') { %>

<div class="error-message">
    <%= error %>
</div>

<% } %>

<!-- ===================== -->
<!-- Update Profile -->
<!-- ===================== -->

<form
action="/admin/profile"
method="POST"
enctype="multipart/form-data"
>

<!-- Profile Photo -->

<div class="profile-photo-box">

<img
src="/uploads/profile/<%= admin.profile_photo || 'default.png' %>"
alt="Admin Photo"
class="profile-photo"
>

</div>

<label>Profile Photo</label>

<input
type="file"
name="profile_photo"
accept=".jpg,.jpeg,.png"
>

<label>Name</label>

<input
type="text"
name="name"
value="<%= admin.name %>"
required
>

<label>Email</label>

<input
type="email"
name="email"
value="<%= admin.email %>"
required
>

<button type="submit">
💾 Update Profile
</button>

</form>

<hr>

<!-- ===================== -->
<!-- Change Password -->
<!-- ===================== -->

<h2>🔒 Change Password</h2>

<form
action="/admin/change-password"
method="POST"
>

<label>Old Password</label>

<input
type="password"
name="oldPassword"
required
>

<label>New Password</label>

<input
type="password"
name="newPassword"
required
>

<button type="submit">
🔑 Change Password
</button>

</form>

</div>

</section>

<%- include("partials/footer") %>

<script src="/js/script.js"></script>

</body>

</html>