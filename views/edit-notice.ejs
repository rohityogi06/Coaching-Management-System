<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Notice</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include("partials/navbar") %>

<section class="form-section">

    <div class="form-container">

        <h2>✏️ Edit Notice</h2>

        <form action="/admin/notices/edit/<%= notice.id %>" method="POST">

            <label>Notice Title</label>

            <input
                type="text"
                name="title"
                value="<%= notice.title %>"
                required
            >

            <label>Description</label>

            <textarea
                name="description"
                rows="5"
                required
            ><%= notice.description %></textarea>

            <label>Notice Date</label>

            <input
                type="date"
                name="notice_date"
                value="<%= notice.notice_date.toISOString().split('T')[0] %>"
                required
            >

            <br><br>

            <button type="submit">
                Update Notice
            </button>

        </form>

        <br>

        <a href="/admin/notices/list" class="btn">
            📋 Back to Notices
        </a>

    </div>

</section>

<%- include("partials/footer") %>
<script src="/js/script.js"></script>
</body>
</html>